# Example .env file for Smart Highlighter Backend
# Copy this to .env and fill in your values

# === Server Configuration ===
HOST=0.0.0.0
PORT=8000
RELOAD=false
HTTPS=false

# === Security ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# === LLM API Keys ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
HUGGINGFACE_API_KEY=

# === LLM Processing ===
DEFAULT_MODEL=gpt-4o-mini
CHUNK_SIZE=3000
CHUNK_OVERLAP=200
MAX_TOKENS=4000

# === Storage ===
DATA_DIR=data
LOG_DIR=logs

# === Scheduler ===
ENABLE_SCHEDULER=true
HOURLY_SUMMARY_TIME=0
DAILY_SUMMARY_TIME=23:55

# === Feature Flags ===
ENABLE_WEB_TRACKING=true
ENABLE_JUDGE=true
