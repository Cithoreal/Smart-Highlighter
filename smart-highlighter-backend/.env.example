# Smart Highlighter Backend - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM API Keys (At least one required)
# =============================================================================

# OpenAI (GPT-4o, GPT-4o-mini)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic (Claude)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIza...

# HuggingFace (Various models)
# Get your key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# =============================================================================
# Server Configuration
# =============================================================================

# Enable HTTPS with self-signed certificate
# Set to 1 for development with HTTPS, 0 for HTTP
# Default: 0
HTTPS=0

# Enable hot reload in development
# Set to 1 for automatic restarts on code changes, 0 for production
# Default: 1
RELOAD=1

# Allowed CORS origins (comma-separated)
# For development: http://localhost:3000
# For production: https://yourdomain.com
# Default: * (WARNING: Too permissive for production!)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Processing Configuration
# =============================================================================

# Maximum tokens per chunk (affects LLM context size)
# Recommended: 5000-10000 depending on model
# Default: 7000
MAX_CHUNK_TOKENS=7000

# Overlap between chunks (maintains context)
# Recommended: 200-500 tokens
# Default: 250
OVERLAP_TOKENS=250

# Number of sliding windows to create
# More chunks = more comprehensive analysis but higher cost
# Default: 1
NUM_CHUNKS=1

# =============================================================================
# Scheduler Configuration
# =============================================================================

# Enable automatic scheduled summarization
# Set to 1 to enable, 0 to disable
# Default: 1
ENABLE_SCHEDULER=1

# Timezone for scheduled tasks
# Use IANA timezone names (e.g., America/New_York, Europe/London)
# Default: UTC
SCHEDULER_TIMEZONE=UTC

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO (use DEBUG for development)
LOG_LEVEL=INFO

# Log file path
# Default: debug.log
LOG_FILE=debug.log

# Maximum log file size in MB
# Default: 10
LOG_MAX_SIZE_MB=10

# Number of backup log files to keep
# Default: 5
LOG_BACKUP_COUNT=5

# =============================================================================
# Database Configuration (Future)
# =============================================================================

# Database URL for SQLite/PostgreSQL
# SQLite: sqlite:///./smart_highlighter.db
# PostgreSQL: postgresql://user:pass@localhost/dbname
# Default: file-based storage (no database)
# DATABASE_URL=sqlite:///./smart_highlighter.db

# =============================================================================
# Redis Configuration (Future)
# =============================================================================

# Redis URL for caching and rate limiting
# Default: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Monitoring & Observability (Future)
# =============================================================================

# Enable Prometheus metrics endpoint
# Default: 0
# ENABLE_METRICS=0

# Sentry DSN for error tracking
# Get your DSN at: https://sentry.io/
# SENTRY_DSN=https://...@sentry.io/...

# =============================================================================
# Feature Flags (Future)
# =============================================================================

# Enable rate limiting
# Default: 0 (not implemented yet)
# ENABLE_RATE_LIMITING=0

# Enable authentication
# Default: 0 (not implemented yet)
# ENABLE_AUTH=0

# =============================================================================
# Notes
# =============================================================================
# 
# - Never commit the .env file to git (it's in .gitignore)
# - Use strong, unique API keys for each service
# - Rotate keys regularly for security
# - For production, use environment variables or secrets management
# - Test configuration with: python -c "import os; print(os.getenv('OPENAI_API_KEY'))"
#
